APP_TITLE="MediVision AI API"
FRONTEND_DIR="backend/static"

# Put your real Gemini key here locally. This file should be copied to .env.
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-2.5-flash-lite"
GEMINI_TEMPERATURE="0.3"
GEMINI_MAX_OUTPUT_TOKENS="1024"

MODEL_DIR="Model"
DISEASE_MODEL_PATH="Model/disease_prediction_pipeline.pkl"
LABEL_ENCODER_PATH="Model/label_encoder.pkl"
TRAINING_DATA_PATH="Model/Training.csv"
SYMPTOM_DESCRIPTION_PATH="Model/symptom_Description.csv"
SYMPTOM_PRECAUTION_PATH="Model/symptom_precaution.csv"
